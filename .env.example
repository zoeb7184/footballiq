# Copy to .env for local overrides. Defaults in config.py match docker-compose.
FIQ_DATABASE_URL=postgresql+psycopg://fiq:fiq_local_dev@localhost:5432/footballiq
FIQ_DATA_DIR=data/raw
# sha256 hashes of accepted API keys (comma-separated). Default-deny: unset = all requests rejected.
# The hash below accepts the local dev key "dev-local-key" — local use only.
FIQ_API_KEY_HASHES=3700285e3c8496a57e45eb1ccd43f2424852788576961320fbb31f86f17edb61
