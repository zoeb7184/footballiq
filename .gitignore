# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv*/
venv/

# Tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# dbt build artifacts
transform/target/
transform/logs/
transform/dbt_packages/

# ML model artifacts (registry references them; files stay local / go to Blob in Azure)
/artifacts/

# Environments & secrets — never in git
.env
.env.*
!.env.example

# Data — never in git (Rule: data lives in storage, git holds code)
# Anchored to repo root: docs/data/ (documentation) must remain trackable.
/data/
*.csv
# Exception: dbt seeds are governance config, not data — versioned on purpose.
!transform/seeds/*.csv
*.parquet
*.sqlite

# IDE / OS
.idea/
.vscode/
.DS_Store
